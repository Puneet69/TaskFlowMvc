@page
@model LoginWithOtpModel
@{
    ViewData["Title"] = "Email verification code";
}

<h1>@ViewData["Title"]</h1>
<p>A verification code was sent to <strong>@Model.Email</strong>.</p>

<div class="row">
    <div class="col-md-5">
        <form method="post">
            <input type="hidden" asp-for="Input.RememberMe" />
            <input type="hidden" asp-for="Input.ReturnUrl" />
            <input type="hidden" asp-for="Input.Email" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
                <label asp-for="Input.Code"></label>
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">Verify and sign in</button>
        </form>
        <form method="post" asp-page-handler="Resend" class="mt-3">
            <input type="hidden" asp-for="Input.Email" />
            <input type="hidden" asp-for="Input.ReturnUrl" />
            <input type="hidden" asp-for="Input.RememberMe" />
            <button type="submit" class="btn btn-outline-secondary w-100">Resend OTP</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
