@model List<TaskFlowMvc.Models.Project>
@{
    ViewData["Title"] = "Projects";
    var teams = ViewBag.Teams as List<TaskFlowMvc.Models.Team> ?? new();
    var activeProjects = Model.Count(p => p.Status == ProjectStatus.Active);
    var planningProjects = Model.Count(p => p.Status == ProjectStatus.Planning);
    var completedProjects = Model.Count(p => p.Status == ProjectStatus.Completed);

    string ProjectStatusClass(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => "tf-status-active",
        ProjectStatus.Planning => "tf-status-planning",
        ProjectStatus.OnHold => "tf-status-hold",
        ProjectStatus.Completed => "tf-status-completed",
        ProjectStatus.Archived => "tf-status-archived",
        _ => ""
    };
}

<div class="page-header mb-4">
    <h1 class="mb-1">Projects</h1>
    <p class="text-muted mb-0">Plan, track, and manage project delivery with teams, milestones, and timelines.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card tf-metric-card border-0">
            <div class="card-body">
                <div class="tf-metric-label">Total Projects</div>
                <div class="tf-metric-value">@Model.Count</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card tf-metric-card border-0">
            <div class="card-body">
                <div class="tf-metric-label">Active + Planning</div>
                <div class="tf-metric-value">@(activeProjects + planningProjects)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card tf-metric-card border-0">
            <div class="card-body">
                <div class="tf-metric-label">Completed</div>
                <div class="tf-metric-value">@completedProjects</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h5 class="tf-card-title">Create Project</h5>
                <p class="tf-card-subtitle">Start a new workspace and assign a team.</p>
                <form asp-action="Create" method="post" class="d-grid gap-3">
                    <div>
                        <label class="form-label">Name</label>
                        <input name="Name" class="form-control" maxlength="100" required />
                    </div>
                    <div>
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" maxlength="500" rows="4" required></textarea>
                    </div>
                    <div>
                        <label class="form-label">Status</label>
                        <select name="Status" class="form-select">
                            @foreach (var status in Enum.GetValues<ProjectStatus>())
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Team (optional)</label>
                        <select name="TeamId" class="form-select">
                            <option value="">Unassigned</option>
                            @foreach (var team in teams)
                            {
                                <option value="@team.Id">@team.Name</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-primary" type="submit">Save Project</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="tf-card-title mb-0">Project List</h5>
                    <span class="badge rounded-pill text-bg-light">@Model.Count items</span>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <h6 class="mb-1">No projects yet</h6>
                        <p class="text-muted mb-0">Create your first project from the left panel.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                            <tr>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Team</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var project in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@project.Name</div>
                                        <div class="small text-muted">@project.Description</div>
                                    </td>
                                    <td><span class="badge tf-status-badge @ProjectStatusClass(project.Status)">@project.Status</span></td>
                                    <td>@(project.Team?.Name ?? "Unassigned")</td>
                                    <td>@project.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@project.Id">Open</a>
                                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@project.Id">Edit</a>
                                            <a class="btn btn-sm btn-outline-secondary" asp-action="Timeline" asp-route-id="@project.Id">Timeline</a>
                                            <form asp-action="Archive" method="post">
                                                <input type="hidden" name="id" value="@project.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Archive</button>
                                            </form>
                                            <form asp-action="Delete" method="post">
                                                <input type="hidden" name="id" value="@project.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
