@model List<(DateTime Date, string Type, string Title, string Description)>
@{
    var project = ViewBag.Project as TaskFlowMvc.Models.Project;
    ViewData["Title"] = "Project Timeline";
}

<div class="page-header mb-4">
    <h1 class="mb-1">Project Timeline</h1>
    <p class="text-muted mb-0">@project?.Name</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">No timeline items yet.</p>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var item in Model)
                {
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <div>
                                <span class="badge text-bg-light">@item.Type</span>
                                <span class="fw-semibold ms-2">@item.Title</span>
                            </div>
                            <small class="text-muted">@item.Date.ToString("dd MMM yyyy")</small>
                        </div>
                        <div class="text-muted small mt-1">@item.Description</div>
                    </li>
                }
            </ul>
        }
        <div class="mt-3">
            <a asp-action="Details" asp-route-id="@project?.Id" class="btn btn-outline-secondary">Back to Project</a>
        </div>
    </div>
</div>
