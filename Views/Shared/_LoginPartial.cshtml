@using Microsoft.AspNetCore.Identity
@using TaskFlowMvc.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var currentDisplayName = currentUser?.DisplayName ?? "User";
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="tf-user-panel">
        <a class="tf-user-name" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            @currentDisplayName
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })">
            <button type="submit" class="tf-user-logout">Logout</button>
        </form>
    </div>
}
else
{
    <div class="tf-auth-links">
        <a class="tf-auth-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
        <a class="tf-auth-link tf-auth-link-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </div>
}
