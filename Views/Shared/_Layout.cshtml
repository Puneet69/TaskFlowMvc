<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TaskFlowMvc.styles.css" asp-append-version="true" />
</head>
<body class="tf-body">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

        string NavClass(string controller, string? action = null)
        {
            var controllerMatch = currentController.Equals(controller, StringComparison.OrdinalIgnoreCase);
            var actionMatch = string.IsNullOrWhiteSpace(action) || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);
            return controllerMatch && actionMatch ? "tf-nav-link active" : "tf-nav-link";
        }
    }

    <div class="tf-shell">
        <aside class="tf-sidebar">
            <div class="tf-sidebar-top">
                <a class="tf-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <span class="tf-brand-mark">T</span>
                    <span class="tf-brand-copy">
                        <strong>TaskFlow</strong>
                        <small>Collaboration Workspace</small>
                    </span>
                </a>

                <div class="tf-sidebar-label">Navigation</div>
                <nav class="tf-nav-menu">
                    <a class="@NavClass("Dashboard", "Index")" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <a class="@NavClass("Projects", "Index")" asp-area="" asp-controller="Projects" asp-action="Index">Projects</a>
                    <a class="@NavClass("Teams", "Index")" asp-area="" asp-controller="Teams" asp-action="Index">Teams</a>
                    <a class="@NavClass("Timeline", "Index")" asp-area="" asp-controller="Timeline" asp-action="Index">Timeline</a>
                    <a class="@NavClass("Notifications", "Index")" asp-area="" asp-controller="Notifications" asp-action="Index">
                        Notifications
                        <span id="notifCountBadge" class="tf-nav-badge d-none">0</span>
                    </a>
                    <a class="@NavClass("Reports", "Index")" asp-area="" asp-controller="Reports" asp-action="Index">Reports</a>
                    <a class="@NavClass("Security", "Index")" asp-area="" asp-controller="Security" asp-action="Index">Security</a>
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <a class="@NavClass("AdminUsers", "Index")" asp-area="" asp-controller="AdminUsers" asp-action="Index">Admin</a>
                    }
                </nav>
            </div>

            <div class="tf-sidebar-footer">
                <partial name="_LoginPartial" />
            </div>
        </aside>

        <div class="tf-main">
            <header class="tf-main-header">
                <div class="tf-main-heading">
                    <h1 class="tf-main-title">@((ViewData["Title"] as string) ?? "TaskFlow")</h1>
                    <p class="tf-main-subtitle">Plan, track, and deliver work in one board.</p>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="tf-main-shortcuts">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-sm btn-outline-primary">Overview</a>
                        <a asp-controller="Projects" asp-action="Index" class="btn btn-sm btn-primary">Open Projects</a>
                    </div>
                }
            </header>

            <main role="main" class="tf-main-content">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success alert-dismissible fade show tf-alert" role="alert">
                        @success
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Info"] is string info)
                {
                    <div class="alert alert-info alert-dismissible fade show tf-alert" role="alert">
                        @info
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger alert-dismissible fade show tf-alert" role="alert">
                        @error
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>

            <footer class="tf-footer">
                <span>&copy; 2026 - TaskFlow</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
        <script>
            (() => {
                const badge = document.getElementById('notifCountBadge');
                const unreadUrl = '@Url.Action("UnreadCount", "Notifications")';
                const notificationsUrl = '@Url.Action("Index", "Notifications")';

                const setCount = (count) => {
                    if (!badge) return;
                    const safeCount = Number.isFinite(count) ? Math.max(0, count) : 0;
                    if (safeCount > 0) {
                        badge.textContent = String(safeCount);
                        badge.classList.remove('d-none');
                    } else {
                        badge.textContent = '0';
                        badge.classList.add('d-none');
                    }
                };

                const loadCount = async () => {
                    try {
                        const response = await fetch(unreadUrl, { credentials: 'same-origin' });
                        if (!response.ok) return;
                        const payload = await response.json();
                        setCount(payload.count ?? 0);
                    } catch (e) {
                        // no-op fallback
                    }
                };

                const escapeHtml = (value) => {
                    return String(value ?? '')
                        .replaceAll('&', '&amp;')
                        .replaceAll('<', '&lt;')
                        .replaceAll('>', '&gt;')
                        .replaceAll('"', '&quot;')
                        .replaceAll("'", '&#39;');
                };

                const appendToast = (title, message, linkUrl) => {
                    const hostId = 'notifToastHost';
                    let host = document.getElementById(hostId);
                    if (!host) {
                        host = document.createElement('div');
                        host.id = hostId;
                        host.className = 'toast-container position-fixed top-0 end-0 p-3';
                        document.body.appendChild(host);
                    }

                    const wrapper = document.createElement('div');
                    wrapper.className = 'toast';
                    wrapper.setAttribute('role', 'alert');
                    wrapper.setAttribute('aria-live', 'assertive');
                    wrapper.setAttribute('aria-atomic', 'true');
                    const safeTitle = escapeHtml(title || 'Notification');
                    const safeMessage = escapeHtml(message || '');
                    const safeLink = escapeHtml(linkUrl || notificationsUrl);
                    wrapper.innerHTML = `
                        <div class="toast-header">
                            <strong class="me-auto">${safeTitle}</strong>
                            <small>just now</small>
                            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body">
                            ${safeMessage}
                            <div class="mt-2">
                                <a class="btn btn-sm btn-outline-primary" href="${safeLink}">Open</a>
                            </div>
                        </div>`;
                    host.appendChild(wrapper);
                    const toast = bootstrap.Toast.getOrCreateInstance(wrapper, { delay: 5000 });
                    toast.show();
                    wrapper.addEventListener('hidden.bs.toast', () => wrapper.remove());
                };

                const startSignalR = async () => {
                    if (!window.signalR) {
                        return false;
                    }

                    try {
                        const connection = new signalR.HubConnectionBuilder()
                            .withUrl('/hubs/notifications')
                            .withAutomaticReconnect()
                            .build();

                        connection.on('notificationReceived', payload => {
                            if (!payload) return;
                            setCount(payload.unreadCount ?? 0);
                            appendToast(payload.title, payload.message, payload.linkUrl);
                        });

                        connection.on('notificationCountUpdated', payload => {
                            setCount(payload?.unreadCount ?? 0);
                        });

                        await connection.start();
                        return true;
                    } catch (e) {
                        return false;
                    }
                };

                loadCount();
                startSignalR().then(started => {
                    if (!started) {
                        window.setInterval(loadCount, 15000);
                    }
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
